---
/**
 * Skills — Technical skill categories + optional soft skills.
 * Uses inline SVG Lucide icons.
 */
import { profile } from '../data/profile';
const { technical, soft } = profile.skills;
if (!technical.length) return;

/* Map icon names to SVG paths (Lucide) */
const icons: Record<string, string> = {
  monitor:   '<path d="M20 3H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2z"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  server:    '<rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>',
  database:  '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
  settings:  '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>',
  lightbulb: '<path d="M9 18h6"/><path d="M10 22h4"/><path d="M12 2a7 7 0 0 0-4 12.7V17h8v-2.3A7 7 0 0 0 12 2z"/>',
  'book-open':'<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>',
  users:     '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
};
---

<section class="section" id="skills">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Skills
      </span>
      <h2 class="section-title">Technical <span class="gradient-text">Expertise</span></h2>
      <p class="section-subtitle">Technologies and tools I work with.</p>
    </div>

    <!-- Technical Skills -->
    <div class="skills-grid stagger">
      {technical.map((cat) => (
        <div class="skill-card glass-card">
          <div class="skill-icon">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <Fragment set:html={icons[cat.icon] || icons.settings} />
            </svg>
          </div>
          <h3 class="skill-cat">{cat.category}</h3>
          <div class="skill-chips">
            {cat.items.map((item) => (
              <span class="chip">{item}</span>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- Soft Skills -->
    {soft.length > 0 && (
      <div class="soft-section reveal">
        <h3 class="soft-heading">Soft Skills</h3>
        <div class="soft-grid stagger">
          {soft.map((s) => (
            <div class="soft-card glass-card">
              <div class="soft-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={icons[s.icon] || icons.lightbulb} />
                </svg>
              </div>
              <div>
                <h4 class="soft-name">{s.name}</h4>
                <p class="soft-desc">{s.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<style>
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
  }

  .skill-card {
    padding: 28px;
  }

  .skill-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(99, 102, 241, 0.1);
    border-radius: 12px;
    color: var(--primary-light);
    margin-bottom: 16px;
  }

  .skill-cat {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-light);
    margin-bottom: 14px;
  }

  .skill-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .chip {
    font-size: 0.8rem;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 50px;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid var(--border);
    color: var(--muted);
    transition: var(--transition);
  }

  .chip:hover {
    color: var(--primary-light);
    border-color: var(--primary);
    background: rgba(99, 102, 241, 0.15);
  }

  /* Soft Skills */
  .soft-section {
    margin-top: 60px;
  }
  .soft-heading {
    text-align: center;
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-light);
    margin-bottom: 28px;
  }
  .soft-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 16px;
  }
  .soft-card {
    display: flex;
    align-items: flex-start;
    gap: 16px;
    padding: 22px;
  }
  .soft-icon {
    flex-shrink: 0;
    width: 42px;
    height: 42px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(168, 85, 247, 0.1);
    border-radius: 10px;
    color: var(--accent-light);
  }
  .soft-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-light);
    margin-bottom: 4px;
  }
  .soft-desc {
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.6;
  }
</style>
