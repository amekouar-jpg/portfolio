---
/**
 * About — Numbered glass cards with left gradient bar and stagger animation.
 */
import { profile } from '../data/profile';
const { about } = profile;
if (!about.length) return;
---

<section class="section" id="about">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        About Me
      </span>
      <h2 class="section-title">Get to <span class="gradient-text">Know Me</span></h2>
      <p class="section-subtitle">A brief introduction to who I am and what drives me.</p>
    </div>

    <div class="about-grid stagger">
      {about.map((text, i) => (
        <div class="about-card glass-card">
          <div class="about-bar" aria-hidden="true"></div>
          <span class="about-num">{String(i + 1).padStart(2, '0')}</span>
          <p class="about-text">{text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  .about-card {
    position: relative;
    padding: 28px 28px 28px 40px;
    overflow: hidden;
  }

  .about-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--gradient);
    border-radius: 0 4px 4px 0;
  }

  .about-card:hover {
    border-top: 1px solid transparent;
    background-image: linear-gradient(var(--glass), var(--glass)),
                      var(--gradient);
    background-origin: border-box;
    background-clip: padding-box, border-box;
  }

  .about-num {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--primary-light);
    opacity: 0.6;
    display: block;
    margin-bottom: 8px;
  }

  .about-text {
    font-size: 1.02rem;
    color: var(--text);
    line-height: 1.8;
  }
</style>
