---
/**
 * Projects — Main showcase section with numbered watermark cards.
 */
import { profile } from '../data/profile';
const { projects } = profile;
if (!projects.length) return;
---

<section class="section" id="projects">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
        Projects
      </span>
      <h2 class="section-title">Featured <span class="gradient-text">Projects</span></h2>
      <p class="section-subtitle">A selection of projects I've built and contributed to.</p>
    </div>

    <div class="projects-grid stagger">
      {projects.map((proj, i) => (
        <div class="project-card glass-card">
          <!-- Watermark number -->
          <span class="project-num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>

          <h3 class="project-title">{proj.title}</h3>
          <p class="project-desc">{proj.description}</p>

          <div class="project-tags">
            {proj.tags.map((tag) => (
              <span class="chip">{tag}</span>
            ))}
          </div>

          <div class="project-links">
            {proj.url && (
              <a href={proj.url} target="_blank" rel="noopener noreferrer" class="project-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
                Source Code
              </a>
            )}
            {proj.live && (
              <a href={proj.live} target="_blank" rel="noopener noreferrer" class="project-link project-link-live">
                View Project
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="arrow-icon"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .project-card {
    position: relative;
    padding: 32px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .project-num {
    position: absolute;
    top: -10px;
    right: 16px;
    font-family: var(--font-mono);
    font-size: 5rem;
    font-weight: 900;
    color: rgba(99, 102, 241, 0.06);
    line-height: 1;
    pointer-events: none;
    user-select: none;
  }

  .project-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-light);
    margin-bottom: 10px;
  }

  .project-desc {
    font-size: 0.92rem;
    color: var(--muted);
    line-height: 1.7;
    margin-bottom: 18px;
    flex: 1;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .chip {
    font-size: 0.78rem;
    font-weight: 500;
    padding: 5px 13px;
    border-radius: 50px;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid var(--border);
    color: var(--muted);
    transition: var(--transition);
  }
  .chip:hover {
    color: var(--primary-light);
    border-color: var(--primary);
  }

  .project-links {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--muted);
    transition: var(--transition);
  }
  .project-link:hover {
    color: var(--primary-light);
  }

  .project-link-live {
    color: var(--primary-light);
  }
  .project-link-live:hover {
    color: var(--accent-light);
  }

  .arrow-icon {
    transition: transform 0.3s ease;
  }
  .project-link-live:hover .arrow-icon {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
