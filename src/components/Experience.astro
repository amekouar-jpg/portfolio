---
/**
 * Experience — Cards with left gradient bar.
 * Only rendered when experience data exists.
 */
import { profile } from '../data/profile';
const { experience } = profile;
if (!experience.length) return;
---

<section class="section" id="experience">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
        Experience
      </span>
      <h2 class="section-title">Work <span class="gradient-text">Experience</span></h2>
    </div>

    <div class="exp-grid stagger">
      {experience.map((exp: any) => (
        <div class="exp-card glass-card">
          <div class="exp-bar" aria-hidden="true"></div>
          <div class="exp-header">
            <div>
              <h3 class="exp-role">{exp.role}</h3>
              <p class="exp-company">{exp.company}</p>
            </div>
            <div class="exp-meta">
              <span class="exp-period">{exp.period}</span>
              {exp.current && <span class="current-badge">Current</span>}
            </div>
          </div>
          <p class="exp-desc">{exp.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .exp-grid {
    display: grid;
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  .exp-card {
    position: relative;
    padding: 28px 28px 28px 40px;
    overflow: hidden;
  }

  .exp-bar {
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--gradient);
    border-radius: 0 4px 4px 0;
  }

  .exp-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 12px;
  }

  .exp-role {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--text-light);
  }

  .exp-company {
    font-size: 0.95rem;
    color: var(--primary-light);
  }

  .exp-meta {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .exp-period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--muted);
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid var(--border);
    padding: 4px 14px;
    border-radius: 50px;
  }

  .current-badge {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 600;
    color: #34d399;
    background: rgba(52, 211, 153, 0.1);
    border: 1px solid rgba(52, 211, 153, 0.2);
    padding: 2px 10px;
    border-radius: 50px;
  }

  .exp-desc {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.7;
  }
</style>
